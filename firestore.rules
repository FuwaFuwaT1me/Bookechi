rules_version = '2';

// Bookechi — каждый пользователь читает/пишет только своё дерево users/{uid}.
// Скопируй это в Firebase Console → Firestore Database → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
